rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection - users can read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Renders collection - users can read their own renders, create new ones, delete their own
    match /renders/{renderId} {
      allow read, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
    
    // Allow listing user's own renders only (Firestore enforces this via query filters)
    match /renders {
      allow list: if request.auth != null && request.query.limit <= 100;
    }
  }
}
