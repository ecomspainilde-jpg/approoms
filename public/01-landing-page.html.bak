<script>
// Г”Г¶ГҮГ”Г¶ГҮ Firebase Config Г”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮ
const firebaseConfig = {
  projectId: "gen-lang-client-0426824151",
  appId: "1:124806819551:web:1c90d1154b458fa064036a",
  storageBucket: "gen-lang-client-0426824151.firebasestorage.app",
  apiKey: "AIzaSyDj99qdmDt4GiVeRkvCSfTOSDw3uqD-_Ew",
  authDomain: "gen-lang-client-0426824151.firebaseapp.com",
  messagingSenderId: "124806819551"
};
firebase.initializeApp(firebaseConfig);

// Г”Г¶ГҮГ”Г¶ГҮ Auth Logic Г”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮ
function handleStart() {
    const user = firebase.auth().currentUser;
    if (user) {
        window.location.href = '02-upload-wizard.html';
    } else {
        openAuth('register');
    }
}

function openAuth(tab) {
    document.getElementById('auth-modal').classList.remove('hidden');
    switchTab(tab || 'login');
    document.body.style.overflow = 'hidden';
}
function closeAuth() {
    document.getElementById('auth-modal').classList.add('hidden');
    document.body.style.overflow = '';
}
document.addEventListener('keydown', e => { if(e.key==='Escape') closeAuth(); });

function switchTab(tab) {
    const isLogin = tab === 'login';
    document.getElementById('form-login').classList.toggle('hidden', !isLogin);
    document.getElementById('form-register').classList.toggle('hidden', isLogin);
    document.getElementById('tab-login').classList.toggle('active', isLogin);
    document.getElementById('tab-register').classList.toggle('active', !isLogin);
    document.getElementById('tab-login').classList.toggle('text-nebula/60', !isLogin);
    document.getElementById('tab-register').classList.toggle('text-nebula/60', isLogin);
}

async function handleRegister() {
    const name = document.getElementById('reg-name').value.trim();
    const email = document.getElementById('reg-email').value.trim();
    const password = document.getElementById('reg-password').value;
    const terms = document.getElementById('reg-terms').checked;
    const msgEl = document.getElementById('reg-msg');
    
    if (!name || !email || !password) { showMsg(msgEl, 'Rellena todos los campos', 'error'); return; }
    if (!terms) { showMsg(msgEl, 'Debes aceptar los tв”ңВ®rminos', 'error'); return; }
    if (password.length < 8) { showMsg(msgEl, 'La contraseв”ңв–’a debe tener al menos 8 caracteres', 'error'); return; }
    
    try {
        const userCredential = await firebase.auth().createUserWithEmailAndPassword(email, password);
        await userCredential.user.updateProfile({ displayName: name });
        showMsg(msgEl, 'в”¬ГӯCuenta creada con в”ңВ®xito!', 'success');
        setTimeout(() => { closeAuth(); }, 1500);
    } catch(e) { 
        showMsg(msgEl, e.message || 'Error al registrar', 'error'); 
    }
}

async function handleLogin() {
    const email = document.getElementById('login-email').value.trim();
    const password = document.getElementById('login-password').value;
    const msgEl = document.getElementById('login-msg');
    
    if (!email || !password) { showMsg(msgEl, 'Introduce email y contraseв”ңв–’a', 'error'); return; }
    
    try {
        await firebase.auth().signInWithEmailAndPassword(email, password);
        showMsg(msgEl, 'в”¬ГӯBienvenido!', 'success');
        setTimeout(() => { closeAuth(); }, 1200);
    } catch(e) { 
        showMsg(msgEl, e.message || 'Error al iniciar sesiв”ңв”Ӯn', 'error'); 
    }
}

async function handleGoogleLogin() {
    const provider = new firebase.auth.GoogleAuthProvider();
    // Force account selection so the user can pick a different account
    provider.setCustomParameters({ prompt: 'select_account' });
    try {
        await firebase.auth().signInWithPopup(provider);
        closeAuth();
        window.location.href = '02-upload-wizard.html';
    } catch (e) {
        // If popup was blocked, fall back to redirect
        if (e.code === 'auth/popup-blocked' || e.code === 'auth/popup-closed-by-user') {
            try {
                await firebase.auth().signInWithRedirect(provider);
            } catch(e2) { /* redirect initiated */ }
            return;
        }
        const msgEl = document.getElementById('tab-login').classList.contains('active') ? 
                      document.getElementById('login-msg') : document.getElementById('reg-msg');
        showMsg(msgEl, e.message || 'Error con Google Sign-in', 'error');
    }
}

async function handleLogout() {
    localStorage.removeItem('rr_token');
    sessionStorage.removeItem('disclaimer_accepted');
    await firebase.auth().signOut();
    window.location.href = '01-landing-page.html';
}

// Allow switching to a different account
async function switchAccount() {
    localStorage.removeItem('rr_token');
    await firebase.auth().signOut();
    openAuth('login');
}

function updateUserUI(user) {
    document.getElementById('user-logged-out').style.display = user ? 'none' : 'flex';
    document.getElementById('user-logged-in').style.display = user ? 'flex' : 'none';
    if (user) {
        document.getElementById('user-greeting').textContent = `Hola, ${user.displayName || user.email.split('@')[0]} ВӯЖ’ГҰГҜ`;
    }
}

firebase.auth().onAuthStateChanged(async user => {
    updateUserUI(user);
    if (user) {
        // Update UI Initials
        const initials = (user.displayName || user.email || 'U').charAt(0).toUpperCase();
        const initialsEl = document.getElementById('user-initials');
        if (initialsEl) initialsEl.textContent = initials;

        // Save token for API calls
        const token = await user.getIdToken();
        localStorage.setItem('rr_token', token);
        
        // Sync user data to Firestore
        syncUserToFirestore(user);
        
        // Check Admin
        const db = firebase.firestore();
        try {
            const doc = await db.collection('users').doc(user.uid).get();
            if (doc.exists && doc.data().isAdmin) {
                document.getElementById('admin-link-container').classList.remove('hidden');
            }
            if (doc.exists) {
                const credits = doc.data().credits || 0;
                const headerDisplay = document.getElementById('header-credits-display');
                const headerCount = document.getElementById('header-credits-count');
                if (headerDisplay) headerDisplay.classList.remove('hidden');
                if (headerCount) headerCount.textContent = credits;
            }
        } catch (e) {
            console.error("Admin check error:", e);
        }
    } else {
        localStorage.removeItem('rr_token');
        document.getElementById('admin-link-container').classList.add('hidden');
        document.getElementById('header-credits-display')?.classList.add('hidden');
    }
    // Always load pricing regardless of auth
    loadDynamicPricing();
});

async function loadDynamicPricing() {
    try {
        const res = await fetch('/api/admin/pricing');
        const data = await res.json();
        
        if (data.render_normal) {
            const priceText = data.render_normal.price.toFixed(2).replace('.', ',') + 'Г”Г©Вј';
            const heroPriceEl = document.getElementById('hero-price');
            const cardPriceEl = document.getElementById('pricing-card-price');
            if (heroPriceEl) heroPriceEl.textContent = priceText;
            if (cardPriceEl) cardPriceEl.textContent = priceText;
        }
    } catch (e) {
        console.error("Error loading dynamic pricing:", e);
    }
}

async function syncUserToFirestore(user) {
    const db = firebase.firestore();
    const userRef = db.collection('users').doc(user.uid);
    
    try {
        const doc = await userRef.get();
        if (!doc.exists) {
            await userRef.set({
                displayName: user.displayName || '',
                email: user.email,
                phone: user.phoneNumber || '',
                location: '',
                isAdmin: false,
                createdAt: firebase.firestore.FieldValue.serverTimestamp()
            });
        }
    } catch (e) {
        console.error("Error syncing user to Firestore:", e);
    }
}

function showMsg(el, text, type) {
    el.textContent = text;
    el.className = `text-center text-sm mt-1 ${type === 'success' ? 'text-green-400' : 'text-red-400'}`;
    el.classList.remove('hidden');
}

// Г”Г¶ГҮГ”Г¶ГҮ Slider Logic Г”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮ
const sliderRange = document.getElementById('slider-range');
const sliderAfter = document.querySelector('.slider-after');
const sliderLine = document.querySelector('.slider-line');
const sliderHandle = document.querySelector('.slider-handle');

if (sliderRange) {
    sliderRange.addEventListener('input', (e) => {
        const val = e.target.value;
        sliderAfter.style.clipPath = `inset(0 0 0 ${val}%)`;
        sliderLine.style.left = `${val}%`;
        sliderHandle.style.left = `${val}%`;
    });
}
</script>
</body>
</html>
