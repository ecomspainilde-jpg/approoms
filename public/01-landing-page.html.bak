<!DOCTYPE html>
<html lang="es">
<head>

<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>RenderRoom AI - Transforma tu Habitaciв”ңв”Ӯn con IA</title>
<meta name="description" content="Rediseв”ңв–’a cualquier habitaciв”ңв”Ӯn con inteligencia artificial. Sube una foto, elige un estilo y recibe un render profesional en segundos por solo 2,50Г”Г©Вј."/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<!-- Firebase SDK -->
<script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-auth-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore-compat.js"></script>
<script id="tailwind-config">
    tailwind.config = {
        darkMode: "class",
        theme: {
            extend: {
                colors: {
                    "primary": "#f0a400",
                    "background-light": "#f8f7f5",
                    "background-dark": "#0D1117",
                    "charcoal": "#161B22",
                    "nebula": "#C9D1D9"
                },
                fontFamily: { "display": ["Inter", "sans-serif"] },
                borderRadius: { "DEFAULT": "0.5rem", "lg": "1rem", "xl": "1.5rem", "full": "9999px" },
            },
        },
    }
</script>
<style>
    .glass-nav { background: rgba(13,17,23,0.7); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }
    .amber-glow { box-shadow: 0 0 20px rgba(240,164,0,0.15); }
    .gradient-border { position: relative; background: #161B22; border-radius: 1.5rem; }
    .gradient-border::before { content:""; position:absolute; inset:-2px; z-index:-1; background:linear-gradient(45deg,#f0a400,#7c3aed); border-radius:1.6rem; }
    /* Auth modal */
    #auth-modal { transition: opacity .3s, visibility .3s; }
    #auth-modal.hidden { opacity:0; visibility:hidden; pointer-events:none; }
    #auth-modal:not(.hidden) { opacity:1; visibility:visible; }
    .modal-card { animation: slideUp .35s ease; }
    @keyframes slideUp { from { opacity:0; transform:translateY(30px) } to { opacity:1; transform:translateY(0) } }
    .tab-btn.active { color:#f0a400; border-bottom-color:#f0a400; }
    .tab-btn { border-bottom:2px solid transparent; transition:all .2s; }
    
    /* Before/After Interaction */
    .slider-container { position: relative; width: 100%; height: 100%; overflow: hidden; }
    .slider-before { position: absolute; inset: 0; background-size: 200% 100%; background-position: 0% center; }
    .slider-after { position: absolute; inset: 0; background-size: 200% 100%; background-position: 100% center; clip-path: inset(0 0 0 50%); }
    .slider-line { position: absolute; top: 0; bottom: 0; left: 50%; width: 2px; background: #f0a400; transform: translateX(-50%); z-index: 20; pointer-events: none; box-shadow: 0 0 15px rgba(240,164,0,0.5); }
    .slider-handle { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 40px; height: 40px; background: #f0a400; border: 2px solid white; border-radius: 50%; display: flex; align-items: center; justify-content: center; z-index: 30; pointer-events: none; color: #0D1117; box-shadow: 0 0 20px rgba(0,0,0,0.5); }
    .slider-input { position: absolute; inset: 0; width: 100%; height: 100%; opacity: 0; cursor: col-resize; z-index: 40; }
    
    .label-glass { position: absolute; bottom: 1rem; padding: 0.25rem 0.75rem; border-radius: 0.5rem; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); z-index: 25; }
</style>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-nebula antialiased selection:bg-primary/30">

<!-- Г”Г¶ГҮГ”Г¶ГҮ AUTH MODAL Г”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮ -->
<div id="auth-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="closeAuth()"></div>
    <div class="modal-card relative w-full max-w-md bg-charcoal rounded-2xl border border-white/10 shadow-2xl overflow-hidden">
        <!-- Close -->
        <button onclick="closeAuth()" class="absolute top-4 right-4 text-nebula/50 hover:text-nebula transition-colors z-10"><span class="material-symbols-outlined">close</span></button>
        <!-- Logo -->
        <div class="p-8 pb-0 text-center">
            <div class="size-12 bg-gradient-to-br from-primary to-orange-600 rounded-xl flex items-center justify-center text-background-dark mx-auto mb-3">
                <span class="material-symbols-outlined">deployed_code</span>
            </div>
            <h2 class="text-2xl font-black">Render<span class="text-primary">Room</span></h2>
        </div>
        <!-- Tabs -->
        <div class="flex border-b border-white/10 mt-6 px-8">
            <button id="tab-login" class="tab-btn active flex-1 py-3 text-sm font-semibold" onclick="switchTab('login')">Iniciar sesiв”ңв”Ӯn</button>
            <button id="tab-register" class="tab-btn flex-1 py-3 text-sm font-semibold text-nebula/60" onclick="switchTab('register')">Crear cuenta</button>
        </div>
        <!-- Login form -->
        <div id="form-login" class="p-8 space-y-4">
            <div>
                <label class="text-xs text-nebula/60 font-semibold uppercase tracking-wider">Email</label>
                <input id="login-email" type="email" placeholder="tu@email.com" class="w-full mt-1 bg-background-dark border border-white/10 rounded-xl px-4 py-3 text-sm text-nebula placeholder-nebula/30 focus:outline-none focus:ring-2 focus:ring-primary/50"/>
            </div>
            <div>
                <label class="text-xs text-nebula/60 font-semibold uppercase tracking-wider">Contraseв”ңв–’a</label>
                <input id="login-password" type="password" placeholder="Г”ГҮГіГ”ГҮГіГ”ГҮГіГ”ГҮГіГ”ГҮГіГ”ГҮГіГ”ГҮГіГ”ГҮГі" class="w-full mt-1 bg-background-dark border border-white/10 rounded-xl px-4 py-3 text-sm text-nebula placeholder-nebula/30 focus:outline-none focus:ring-2 focus:ring-primary/50"/>
            </div>
            <button onclick="handleLogin()" class="w-full bg-primary hover:bg-primary/90 text-background-dark font-black py-3 rounded-xl transition-all amber-glow">
                Entrar
            </button>
            <div class="relative py-2">
                <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-white/10"></div></div>
                <div class="relative flex justify-center text-xs uppercase"><span class="bg-charcoal px-2 text-nebula/40">O continuar con</span></div>
            </div>
            <button onclick="handleGoogleLogin()" class="w-full bg-white hover:bg-slate-100 text-slate-900 font-bold py-3 rounded-xl transition-all flex items-center justify-center gap-2">
                <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" class="size-5" alt="Google"/>
                Google
            </button>
            <p class="text-center text-xs text-nebula/40">в”¬в”җOlvidaste tu contraseв”ңв–’a? <a href="privacidad.html" class="text-primary hover:underline">Recupв”ңВ®rala</a></p>
            <div id="login-msg" class="text-center text-sm hidden"></div>
        </div>
        <!-- Register form -->
        <div id="form-register" class="hidden p-8 space-y-4">
            <div>
                <label class="text-xs text-nebula/60 font-semibold uppercase tracking-wider">Nombre completo</label>
                <input id="reg-name" type="text" placeholder="Marв”ңВЎa Garcв”ңВЎa" class="w-full mt-1 bg-background-dark border border-white/10 rounded-xl px-4 py-3 text-sm text-nebula placeholder-nebula/30 focus:outline-none focus:ring-2 focus:ring-primary/50"/>
            </div>
            <div>
                <label class="text-xs text-nebula/60 font-semibold uppercase tracking-wider">Email</label>
                <input id="reg-email" type="email" placeholder="tu@email.com" class="w-full mt-1 bg-background-dark border border-white/10 rounded-xl px-4 py-3 text-sm text-nebula placeholder-nebula/30 focus:outline-none focus:ring-2 focus:ring-primary/50"/>
            </div>
            <div>
                <label class="text-xs text-nebula/60 font-semibold uppercase tracking-wider">Contraseв”ңв–’a</label>
                <input id="reg-password" type="password" placeholder="Mв”ңВЎnimo 8 caracteres" class="w-full mt-1 bg-background-dark border border-white/10 rounded-xl px-4 py-3 text-sm text-nebula placeholder-nebula/30 focus:outline-none focus:ring-2 focus:ring-primary/50"/>
            </div>
            <div class="flex items-start gap-3">
                <input id="reg-terms" type="checkbox" class="mt-1 rounded border-white/20 bg-background-dark text-primary focus:ring-primary/50"/>
                <label for="reg-terms" class="text-xs text-nebula/60 leading-relaxed">Acepto los <a href="terminos.html" class="text-primary hover:underline">tв”ңВ®rminos de uso</a> y la <a href="privacidad.html" class="text-primary hover:underline">polв”ңВЎtica de privacidad</a></label>
            </div>
            <button onclick="handleRegister()" class="w-full bg-primary hover:bg-primary/90 text-background-dark font-black py-3 rounded-xl transition-all amber-glow">
                Crear cuenta gratuita
            </button>
            <div class="relative py-2">
                <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-white/10"></div></div>
                <div class="relative flex justify-center text-xs uppercase"><span class="bg-charcoal px-2 text-nebula/40">O continuar con</span></div>
            </div>
            <button onclick="handleGoogleLogin()" class="w-full bg-white hover:bg-slate-100 text-slate-900 font-bold py-3 rounded-xl transition-all flex items-center justify-center gap-2">
                <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" class="size-5" alt="Google"/>
                Google
            </button>
            <div id="reg-msg" class="text-center text-sm hidden"></div>
        </div>
    </div>
</div>

<!-- Г”Г¶ГҮГ”Г¶ГҮ NAV Г”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮ -->
<nav class="fixed top-0 left-0 right-0 z-50 glass-nav border-b border-white/10">
    <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
        <div class="flex items-center gap-3">
            <div class="size-10 bg-gradient-to-br from-primary to-orange-600 rounded-lg flex items-center justify-center text-background-dark">
                <span class="material-symbols-outlined font-bold">deployed_code</span>
            </div>
            <h1 class="text-slate-100 text-2xl font-black tracking-tight">Render<span class="text-primary">Room</span></h1>
        </div>
        <div class="hidden md:flex items-center gap-10">
            <a class="text-sm font-medium hover:text-primary transition-colors" href="#como-funciona">Cв”ңв”Ӯmo Funciona</a>
            <a class="text-sm font-medium hover:text-primary transition-colors" href="#galeria">Galerв”ңВЎa</a>
            <a class="text-sm font-medium hover:text-primary transition-colors" href="#precios">Precios</a>
            <a class="text-sm font-medium hover:text-primary transition-colors" href="07-consejos-decoracion.html">Blog</a>
            <a class="text-sm font-medium hover:text-primary transition-colors" href="03-dashboard.html">Mis Renders</a>
        </div>
        <div class="flex items-center gap-3">
            <!-- User status display -->
            <div id="user-logged-out" class="flex items-center gap-3">
                <button onclick="openAuth('login')" class="text-sm text-nebula/70 hover:text-primary transition-colors font-medium hidden md:block">Iniciar sesiв”ңв”Ӯn</button>
                <button onclick="openAuth('register')" class="bg-primary hover:bg-primary/90 text-background-dark px-5 py-2 rounded-xl text-sm font-bold tracking-wide transition-all hover:scale-105 amber-glow">Crear cuenta</button>
            </div>
            <div id="user-logged-in" class="hidden items-center gap-3">
                <div id="header-credits-display" class="hidden flex items-center gap-2 px-3 py-1.5 bg-primary/10 border border-primary/20 rounded-full">
                    <span class="material-symbols-outlined text-primary text-sm">toll</span>
                    <span id="header-credits-count" class="text-primary text-sm font-bold">--</span>
                    <span class="text-xs text-slate-400">crв”ңВ®ditos</span>
                </div>
                <div id="admin-link-container" class="hidden">
                    <a href="admin-dashboard.html" class="text-primary hover:text-primary/80 transition-colors">
                        <span class="material-symbols-outlined">admin_panel_settings</span>
                    </a>
                </div>
                <span id="user-greeting" class="text-sm text-nebula/70 hidden md:block"></span>
                <a href="06-perfil-usuario.html" class="flex items-center gap-2 group" title="Ver perfil">
                    <div id="user-initials" class="w-8 h-8 rounded-full bg-primary/20 border border-primary/30 flex items-center justify-center text-primary font-bold text-xs group-hover:bg-primary/30 transition-colors">
                        U
                    </div>
                </a>
                <div class="flex flex-col gap-0.5">
                    <button onclick="handleLogout()" class="text-[10px] text-nebula/40 hover:text-red-400 transition-colors border border-white/5 hover:border-red-500/30 px-2 py-1 rounded leading-tight">Salir</button>
                    <button onclick="switchAccount()" class="text-[9px] text-nebula/30 hover:text-primary transition-colors leading-tight">Cambiar cuenta</button>
                </div>
                <a href="02-upload-wizard.html" class="bg-primary hover:bg-primary/90 text-background-dark px-5 py-2 rounded-xl text-sm font-bold tracking-wide transition-all hover:scale-105 amber-glow">Renderiza Ahora</a>
            </div>
        </div>
    </div>
</nav>

<main class="pt-32">
    <!-- Г”Г¶ГҮГ”Г¶ГҮ HERO Г”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮ -->
    <section class="max-w-7xl mx-auto px-6 py-12 lg:py-20">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
            <div class="space-y-8">
                <div class="inline-flex items-center gap-2 bg-primary/10 border border-primary/20 px-4 py-1.5 rounded-full">
                    <span class="size-2 bg-primary rounded-full animate-pulse"></span>
                    <span class="text-primary text-xs font-bold uppercase tracking-widest">Nueva IA Generativa V4</span>
                </div>
                <h2 class="text-5xl lg:text-7xl font-black text-slate-100 leading-[1.1] tracking-tight">
                    Transforma tu Habitaciв”ңв”Ӯn <br/>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-orange-400">con IA</span>
                </h2>
                <div class="flex flex-col gap-4">
                    <div class="flex items-baseline gap-4">
                        <span class="text-6xl font-black text-primary" id="hero-price">2,50Г”Г©Вј</span>
                        <div class="flex flex-col">
                            <span class="text-slate-500 line-through text-lg font-medium">3,50Г”Г©Вј precio de un perrito</span>
                            <span class="bg-white/5 border border-white/10 text-white text-[10px] font-bold px-2 py-0.5 rounded-md w-fit mt-1">в”¬Гӯ1Г”Г©Вј MENOS!</span>
                        </div>
                    </div>
                    <p class="text-lg text-slate-400 max-w-md">Rediseв”ңв–’a cualquier espacio en segundos con realismo fotogrв”ңГӯfico profesional. Sin arquitectos, sin esperas.</p>
                </div>
                <div class="flex flex-col sm:flex-row gap-4">
                    <button onclick="handleStart()" class="bg-gradient-to-r from-primary to-orange-500 hover:opacity-90 text-background-dark px-8 py-4 rounded-xl text-lg font-black transition-all hover:scale-105 amber-glow flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined">upload_file</span> Sube tu Foto Ahora
                    </button>
                    <button onclick="openAuth('register')" class="border border-white/10 hover:border-primary/40 text-nebula px-8 py-4 rounded-xl text-lg font-semibold transition-all hover:scale-105 flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-primary">person_add</span> Crear cuenta gratis
                    </button>
                </div>
            </div>
            <div class="relative group">
                <div class="absolute -inset-4 bg-primary/20 blur-3xl rounded-full opacity-30"></div>
                <div class="relative rounded-2xl overflow-hidden border border-white/10 shadow-2xl aspect-[4/3] bg-background-dark">
                    <div class="slider-container" id="hero-slider">
                        <!-- Before layer (Messy room) -->
                        <div class="slider-before bg-[url('img/hero_split.png')]"></div>
                        
                        <!-- After layer (Modern room) -->
                        <div class="slider-after bg-[url('img/hero_split.png')]"></div>
                        
                        <!-- Divider Line -->
                        <div class="slider-line"></div>
                        
                        <!-- Handle -->
                        <div class="slider-handle">
                            <span class="material-symbols-outlined">compare_arrows</span>
                        </div>

                        <!-- Labels -->
                        <div class="label-glass left-4 bg-background-dark/60 text-white">Antes</div>
                        <div class="label-glass right-4 bg-primary/90 text-background-dark">Despuв”ңВ®s (IA)</div>

                        <!-- Interaction Input -->
                        <input type="range" min="0" max="100" value="50" class="slider-input" id="slider-range">
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Г”Г¶ГҮГ”Г¶ГҮ COMO FUNCIONA Г”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮГ”Г¶ГҮ -->
    <section id="como-funciona" class="max-w-7xl mx-auto px-6 py-24 border-t border-white/5">
        <div class="text-center mb-16 space-y-4">
            <h2 class="text-3xl lg:text-4xl font-black text-slate-100">Cв”ңв”Ӯmo Funciona</h2>
            <p class="text-slate-400">Tu nuevo hogar estв”ңГӯ a solo tres pasos</p>
        </div>
        <div class="relative">
            <div class="hidden lg:block absolute top-1/2 left-0 w-full h-px border-t border-dashed border-primary/30 -z-10"></div>
            <div class="grid md:grid-cols-3 gap-8">
                <div class="bg-charcoal p-8 rounded-2xl border border-white/5 flex flex-col items-center text-center group hover:border-primary/30 transition-colors">
                    <div class="size-16 bg-primary/10 text-primary rounded-full flex items-center justify-center mb-6 group-hover:bg-primary group-hover:text-background-dark transition-all">
                        <span class="material-symbols-outlined text-3xl">add_photo_alternate</span>
                    </div>
                    <h3 class="text-xl font-bold text-slate-100 mb-2">Sube tu Foto</h3>
